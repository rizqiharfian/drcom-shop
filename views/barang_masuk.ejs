<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Barang Masuk</title>
  <link rel="icon" href="/drcom.png" type="image/png">

  <!-- Bootstrap -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />

  <!-- SELECT2 -->
  <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />

  <!-- JQUERY (WAJIB sebelum select2) -->
  <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

  <!-- SELECT2 JS -->
  <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
</head>

<body class="bg-light">

<!-- NAVBAR -->
<nav class="navbar navbar-expand-lg navbar-dark bg-dark mb-4">
  <div class="container">
    <a class="navbar-brand" href="/">Manajemen Toko</a>

    <div class="collapse navbar-collapse">
      <ul class="navbar-nav ms-auto">
        <% const currentPath = typeof path !== 'undefined' ? path : '/'; %>
        <li class="nav-item"><a class="nav-link <%= currentPath === '/' ? 'active' : '' %>" href="/">Beranda</a></li>
        <li class="nav-item"><a class="nav-link active" href="/barang-masuk">Barang Masuk</a></li>
        <li class="nav-item"><a class="nav-link" href="/barang-keluar">Barang Keluar</a></li>
        <li class="nav-item"><a class="nav-link" href="/produk">Produk</a></li>
      </ul>
    </div>
  </div>
</nav>

<div class="container mt-5">
  <h2 class="text-center mb-4">Form Barang Masuk</h2>

  <form action="/barang-masuk" method="POST" id="formMasuk" enctype="multipart/form-data">

    <!-- Pengirim -->
    <div class="mb-3">
      <label class="form-label">Nama Pengirim</label>
      <input type="text" class="form-control" name="pengirim" id="pengirim" required />
    </div>

    <!-- TABLE -->
    <table class="table table-bordered text-center">
      <thead class="table-primary">
        <tr>
          <th>Produk</th>
          <th>Nama Baru</th>
          <th>Jumlah</th>
          <th>Keterangan</th>
          <th>Gambar</th>
          <th>Aksi</th>
        </tr>
      </thead>

      <tbody id="itemsContainer">
        <tr class="item-row">
          <td>
            <select name="produk[]" class="form-select produk-select" required>
              <option value="">-- Pilih Produk --</option>
              <% produk.forEach(p => { %>
                <option value="<%= p.id %>"><%= p.nama %></option>
              <% }) %>
              <option value="__TAMBAH_BARU__">+ Tambah Baru</option>
            </select>
          </td>

          <td>
            <input type="text" name="produk_nama[]" class="form-control produk-nama" style="display:none;">
          </td>

          <td>
            <input type="number" name="jumlah[]" class="form-control jumlah" min="1" required>
          </td>

          <td>
            <input type="text" name="keterangan[]" class="form-control">
          </td>

          <td>
            <input type="file" name="gambar" class="form-control">
          </td>

          <td>
            <button type="button" class="btn btn-danger btn-sm removeRow">Hapus</button>
          </td>
        </tr>
      </tbody>
    </table>

    <div class="text-center">
      <button type="button" id="addRow" class="btn btn-success mb-3">+ Tambah Produk</button><br>
      <button type="submit" class="btn btn-primary">Simpan</button>
    </div>

  </form>
</div>

<script>
/* =========================
   INIT SELECT2
========================= */
function initSelect2() {
  $('.produk-select').select2({
    placeholder: '-- Cari Produk (contoh: laptop asus) --',
    allowClear: true,
    width: '100%'
  });
}

$(document).ready(function () {
  initSelect2();
});


/* =========================
   TAMBAH ROW
========================= */
$('#addRow').click(function () {

  let clone = $('.item-row:first').clone();

  // reset semua input
  clone.find('input').val('');
  clone.find('select').val('');

  clone.find('.produk-nama').hide();

  // HAPUS select2 lama (penting!)
  clone.find('.select2-container').remove();
  clone.find('select').removeClass('select2-hidden-accessible');

  $('#itemsContainer').append(clone);

  // init ulang select2
  initSelect2();
});


/* =========================
   HAPUS ROW
========================= */
$(document).on('click', '.removeRow', function () {
  if ($('.item-row').length > 1) {
    $(this).closest('tr').remove();
  }
});


/* =========================
   TOGGLE TAMBAH BARU
========================= */
$(document).on('change', '.produk-select', function () {
  let tr = $(this).closest('tr');
  let input = tr.find('.produk-nama');

  if ($(this).val() === '__TAMBAH_BARU__') {
    input.show().prop('required', true);
  } else {
    input.hide().prop('required', false);
  }
});


/* =========================
   VALIDASI
========================= */
$('#formMasuk').submit(function (e) {

  let pengirim = $('#pengirim').val().trim();
  if (!pengirim) {
    e.preventDefault();
    alert('Isi nama pengirim');
    return;
  }

  let valid = false;

  $('.item-row').each(function () {
    let produk = $(this).find('.produk-select').val();
    let manual = $(this).find('.produk-nama').val();
    let jumlah = $(this).find('.jumlah').val();

    if ((produk || manual) && jumlah > 0) {
      valid = true;
    }
  });

  if (!valid) {
    e.preventDefault();
    alert('Minimal 1 produk harus diisi');
  }
});
</script>

</body>
</html>